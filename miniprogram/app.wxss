page {
  min-height: 100vh;
  background:
    radial-gradient(circle at 88% 4%, rgba(255,255,255,.92), transparent 24%),
    radial-gradient(circle at 12% 16%, rgba(191,230,238,.52), transparent 34%),
    linear-gradient(180deg, #f3fbfd 0%, #e6f2f6 62%, #dbe9ef 100%);
  color: #162a34;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", sans-serif;
}

view,
text,
button,
input,
textarea {
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
  border: 0;
  background: transparent;
  line-height: 1.4;
  font: inherit;
  overflow: visible;
}

button::after {
  border: 0;
}

.page {
  min-height: 100vh;
  padding: 86rpx 24rpx 176rpx;
}

.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 88rpx;
  margin-bottom: 24rpx;
}

.brand {
  display: flex;
  align-items: center;
  gap: 22rpx;
}

.brand-mark {
  width: 76rpx;
  height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid rgba(18, 125, 143, 0.18);
  border-radius: 22rpx;
  background: linear-gradient(180deg, rgba(255,255,255,.94), rgba(226,244,249,.9));
  box-shadow: 0 16rpx 28rpx rgba(21,91,116,.12), inset 0 0 0 10rpx rgba(18,125,143,.05);
}

.brand-sprout {
  width: 36rpx;
  height: 48rpx;
  position: relative;
}

.brand-sprout::before,
.brand-sprout::after {
  content: "";
  position: absolute;
  border: 4rpx solid #127d8f;
}

.brand-sprout::before {
  left: 16rpx;
  top: 2rpx;
  height: 44rpx;
  border-left-width: 0;
  border-top-width: 0;
  border-bottom-width: 0;
}

.brand-sprout::after {
  left: 0;
  top: 18rpx;
  width: 34rpx;
  height: 22rpx;
  border-radius: 0 28rpx 0 28rpx;
  border-right-width: 0;
  transform: rotate(14deg);
}

.brand-title {
  display: block;
  font-family: "Songti SC", "STSong", serif;
  font-size: 36rpx;
  font-weight: 900;
  line-height: 1.1;
}

.brand-subtitle {
  display: block;
  margin-top: 4rpx;
  color: #607582;
  font-size: 23rpx;
}

.reminder-button,
.icon-button {
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid rgba(169,194,205,.72);
  border-radius: 22rpx;
  background: rgba(248,252,255,.88);
  color: #127d8f;
  box-shadow: 0 12rpx 28rpx rgba(21,65,86,.09);
}

.icon-button {
  width: 76rpx;
  height: 76rpx;
}

.reminder-button {
  min-width: 148rpx;
  height: 72rpx;
  gap: 12rpx;
  padding: 0 18rpx;
}

.reminder-icon {
  width: 24rpx;
  height: 28rpx;
  border: 4rpx solid #127d8f;
  border-radius: 20rpx 20rpx 12rpx 12rpx;
  border-bottom-width: 2rpx;
}

.reminder-copy {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  line-height: 1.05;
}

.reminder-copy text:first-child {
  color: #127d8f;
  font-size: 24rpx;
  font-weight: 900;
}

.reminder-copy text:last-child {
  margin-top: 6rpx;
  color: #607582;
  font-size: 20rpx;
  font-weight: 800;
}

.section-kicker {
  color: #607582;
  font-size: 24rpx;
  font-weight: 800;
}

.section-title {
  display: block;
  margin: 8rpx 0 26rpx;
  font-family: "Songti SC", "STSong", serif;
  font-size: 52rpx;
  font-weight: 900;
  line-height: 1.15;
}

.card {
  border: 2rpx solid rgba(169,194,205,.72);
  border-radius: 28rpx;
  background: linear-gradient(180deg, rgba(248,252,255,.97), rgba(233,244,248,.92));
  box-shadow: 0 18rpx 44rpx rgba(21,65,86,.1), inset 0 2rpx 0 rgba(255,255,255,.9);
}

.sheet-label {
  display: inline-flex;
  align-items: center;
  min-height: 42rpx;
  padding: 0 18rpx;
  border: 2rpx solid rgba(18,125,143,.2);
  border-radius: 999rpx;
  background: rgba(222,244,249,.92);
  color: #127d8f;
  font-size: 23rpx;
  font-weight: 900;
}

.primary-button,
.secondary-button,
.ghost-button {
  min-height: 92rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 24rpx;
  font-size: 30rpx;
  font-weight: 900;
}

.primary-button {
  background: linear-gradient(180deg, #19a2b5, #086578);
  color: #fff;
  box-shadow: 0 16rpx 28rpx rgba(18,125,143,.23), inset 0 2rpx 0 rgba(255,255,255,.22);
}

.secondary-button,
.ghost-button {
  border: 2rpx solid rgba(169,194,205,.72);
  background: rgba(248,252,255,.78);
  color: #162a34;
}

.button-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 24rpx;
}

.button-row button {
  flex: 1 1 190rpx;
}

.bottom-dock {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(24rpx + env(safe-area-inset-bottom));
  z-index: 20;
  display: flex;
  border: 2rpx solid rgba(169,194,205,.78);
  border-radius: 30rpx;
  background: rgba(248,252,255,.92);
  box-shadow: 0 18rpx 40rpx rgba(21,65,86,.16), inset 0 2rpx 0 rgba(255,255,255,.9);
  padding: 10rpx;
}

.dock-item {
  flex: 1;
  min-width: 0;
  height: 88rpx;
  min-height: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  margin: 0 4rpx;
  border-radius: 22rpx;
  background: transparent;
  color: #607582;
  font-size: 21rpx;
  font-weight: 800;
}

.dock-item.is-active {
  background: linear-gradient(180deg, #19a2b5, #086578);
  color: #fff;
}

.dock-icon {
  font-size: 26rpx;
  line-height: 1;
}

.muted {
  color: #607582;
}

.microcopy {
  color: #607582;
  font-size: 26rpx;
  line-height: 1.65;
}

.empty-state {
  padding: 56rpx 32rpx;
  text-align: center;
}
