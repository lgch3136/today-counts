page {
  min-height: 100vh;
  background:
    radial-gradient(circle at 88% 5%, rgba(255, 255, 255, 0.94), transparent 24%),
    linear-gradient(180deg, #fff8ed 0%, #f0e3d1 70%, #e7d7bf 100%);
  color: #2b261f;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", sans-serif;
}

view,
text,
button,
input,
textarea {
  box-sizing: border-box;
}

button {
  padding: 0;
  line-height: 1.4;
  font: inherit;
}

button::after {
  border: 0;
}

.page {
  min-height: 100vh;
  padding: 86rpx 24rpx 176rpx;
}

.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 88rpx;
  margin-bottom: 24rpx;
}

.brand {
  display: flex;
  align-items: center;
  gap: 22rpx;
}

.brand-mark {
  width: 76rpx;
  height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid rgba(46, 112, 89, 0.18);
  border-radius: 22rpx;
  background: linear-gradient(180deg, rgba(255,255,255,.92), rgba(229,242,232,.9));
  box-shadow: 0 16rpx 28rpx rgba(46,112,89,.12), inset 0 0 0 10rpx rgba(46,112,89,.05);
}

.brand-sprout {
  width: 36rpx;
  height: 48rpx;
  position: relative;
}

.brand-sprout::before,
.brand-sprout::after {
  content: "";
  position: absolute;
  border: 4rpx solid #2e7059;
}

.brand-sprout::before {
  left: 16rpx;
  top: 2rpx;
  height: 44rpx;
  border-left-width: 0;
  border-top-width: 0;
  border-bottom-width: 0;
}

.brand-sprout::after {
  left: 0;
  top: 18rpx;
  width: 34rpx;
  height: 22rpx;
  border-radius: 0 28rpx 0 28rpx;
  border-right-width: 0;
  transform: rotate(14deg);
}

.brand-title {
  display: block;
  font-family: "Songti SC", "STSong", serif;
  font-size: 36rpx;
  font-weight: 900;
  line-height: 1.1;
}

.brand-subtitle {
  display: block;
  margin-top: 4rpx;
  color: #817364;
  font-size: 23rpx;
}

.notify-button,
.icon-button {
  width: 76rpx;
  height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid rgba(226,207,175,.92);
  border-radius: 22rpx;
  background: rgba(255,249,238,.88);
  color: #2e7059;
  box-shadow: 0 12rpx 28rpx rgba(74,48,25,.09);
}

.notify-dot {
  width: 24rpx;
  height: 28rpx;
  border: 4rpx solid #2e7059;
  border-radius: 20rpx 20rpx 12rpx 12rpx;
  border-bottom-width: 2rpx;
}

.section-kicker {
  color: #817364;
  font-size: 24rpx;
  font-weight: 800;
}

.section-title {
  display: block;
  margin: 8rpx 0 26rpx;
  font-family: "Songti SC", "STSong", serif;
  font-size: 52rpx;
  font-weight: 900;
  line-height: 1.15;
}

.card {
  border: 2rpx solid rgba(226,207,175,.9);
  border-radius: 28rpx;
  background: linear-gradient(180deg, rgba(255,253,248,.97), rgba(255,247,235,.92));
  box-shadow: 0 18rpx 44rpx rgba(80,52,28,.1), inset 0 2rpx 0 rgba(255,255,255,.9);
}

.sheet-label {
  display: inline-flex;
  align-items: center;
  min-height: 42rpx;
  padding: 0 18rpx;
  border: 2rpx solid rgba(46,112,89,.2);
  border-radius: 999rpx;
  background: rgba(220,236,225,.92);
  color: #2e7059;
  font-size: 23rpx;
  font-weight: 900;
}

.primary-button,
.secondary-button,
.ghost-button {
  min-height: 92rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 24rpx;
  font-size: 30rpx;
  font-weight: 900;
}

.primary-button {
  background: linear-gradient(180deg, #2f8a66, #17563d);
  color: #fff;
  box-shadow: 0 16rpx 28rpx rgba(46,112,89,.23), inset 0 2rpx 0 rgba(255,255,255,.22);
}

.secondary-button,
.ghost-button {
  border: 2rpx solid rgba(226,207,175,.9);
  background: rgba(255,253,248,.78);
  color: #2b261f;
}

.button-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 24rpx;
}

.button-row button {
  flex: 1 1 190rpx;
}

.bottom-dock {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(24rpx + env(safe-area-inset-bottom));
  z-index: 20;
  display: flex;
  border: 2rpx solid rgba(226,207,175,.88);
  border-radius: 30rpx;
  background: rgba(255,250,240,.92);
  box-shadow: 0 18rpx 40rpx rgba(85,55,28,.18), inset 0 2rpx 0 rgba(255,255,255,.9);
  padding: 10rpx;
}

.dock-item {
  flex: 1;
  min-width: 0;
  height: 88rpx;
  min-height: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  margin: 0 4rpx;
  border-radius: 22rpx;
  background: transparent;
  color: #817364;
  font-size: 21rpx;
  font-weight: 800;
}

.dock-item.is-active {
  background: linear-gradient(180deg, #2f8a66, #17563d);
  color: #fff;
}

.dock-icon {
  font-size: 26rpx;
  line-height: 1;
}

.muted {
  color: #817364;
}

.microcopy {
  color: #817364;
  font-size: 26rpx;
  line-height: 1.65;
}

.empty-state {
  padding: 56rpx 32rpx;
  text-align: center;
}
