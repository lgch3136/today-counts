.progress-hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 34rpx;
  margin-bottom: 26rpx;
}

.progress-hero > view:first-child {
  flex: 1;
  min-width: 0;
  padding-right: 26rpx;
}

.progress-kicker {
  color: #817364;
  font-size: 24rpx;
  font-weight: 800;
}

.progress-title {
  display: block;
  margin: 10rpx 0 12rpx;
  font-family: "Songti SC", "STSong", serif;
  font-size: 44rpx;
  font-weight: 900;
  line-height: 1.12;
}

.progress-ring {
  flex: 0 0 176rpx;
  width: 176rpx;
  height: 176rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 18rpx solid #2e7059;
  border-left-color: #e2cfaf;
  border-radius: 50%;
  background: #fff9ee;
}

.progress-ring text:first-child {
  color: #2e7059;
  font-size: 44rpx;
  font-weight: 950;
  line-height: 1;
}

.progress-ring text:last-child {
  margin-top: 8rpx;
  color: #817364;
  font-size: 20rpx;
  font-weight: 800;
}

.flag-card,
.mood-card,
.calendar-card {
  position: relative;
  margin-bottom: 26rpx;
  padding: 32rpx;
}

.flag-card::before {
  content: "";
  position: absolute;
  top: -2rpx;
  right: 52rpx;
  width: 94rpx;
  height: 32rpx;
  border-radius: 0 0 14rpx 14rpx;
  background: rgba(245, 203, 124, 0.76);
}

.flag-title {
  display: block;
  margin: 26rpx 0 12rpx;
  font-family: "Songti SC", "STSong", serif;
  font-size: 42rpx;
  font-weight: 900;
  line-height: 1.18;
}

.meter-card {
  margin-top: 26rpx;
  border: 2rpx solid rgba(226,207,175,.84);
  border-radius: 26rpx;
  background: linear-gradient(135deg, rgba(220,236,225,.74), rgba(255,253,248,.84));
  padding: 26rpx;
}

.meter-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  color: #817364;
  font-size: 24rpx;
  font-weight: 850;
}

.meter-head text:last-child {
  color: #2e7059;
  font-size: 58rpx;
  line-height: 1;
  font-weight: 950;
}

.track {
  height: 14rpx;
  border-radius: 999rpx;
  background: rgba(226,207,175,.55);
  overflow: hidden;
}

.track view {
  height: 100%;
  border-radius: 999rpx;
  background: #2e7059;
}

.reason-panel {
  margin-top: 24rpx;
  border-top: 2rpx dashed rgba(226,207,175,.9);
  padding-top: 22rpx;
}

.reason-grid,
.mood-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  margin-top: 18rpx;
}

.reason-button,
.mood-button {
  width: 48%;
  min-height: 86rpx;
  margin-bottom: 14rpx;
  border: 2rpx solid rgba(226,207,175,.9);
  border-radius: 24rpx;
  background: rgba(255,253,248,.78);
  color: #2b261f;
  font-size: 28rpx;
  font-weight: 850;
}

.mood-button.is-active {
  border-color: rgba(46,112,89,.44);
  background: #dcece1;
  color: #2e7059;
}

.log-card {
  margin-top: 26rpx;
  border-top: 2rpx dashed rgba(226,207,175,.9);
  padding-top: 22rpx;
}

.log-row {
  display: flex;
  align-items: center;
  padding: 14rpx 0;
  border-bottom: 1rpx solid rgba(226,207,175,.68);
  color: #817364;
  font-size: 23rpx;
  font-weight: 800;
}

.log-row text:first-child {
  width: 96rpx;
  flex: 0 0 96rpx;
}

.log-row text:nth-child(2) {
  flex: 1;
  min-width: 0;
  padding: 0 12rpx;
}

.log-row text:last-child {
  width: 80rpx;
  flex: 0 0 80rpx;
  color: #2e7059;
  text-align: right;
}

.empty-flag-image {
  display: block;
  width: 184rpx;
  height: 184rpx;
  margin: 0 auto 26rpx;
  border-radius: 36rpx;
  box-shadow: 0 16rpx 34rpx rgba(78,51,27,.12);
}

.empty-title {
  display: block;
  margin-bottom: 12rpx;
  font-family: "Songti SC", "STSong", serif;
  font-size: 42rpx;
  font-weight: 900;
}

.empty-state .primary-button {
  margin-top: 28rpx;
}

.calendar-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  text-align: center;
  margin-bottom: 18rpx;
}

.calendar-head > view {
  flex: 1;
  min-width: 0;
}

.calendar-head button {
  width: 76rpx;
  height: 76rpx;
  border-radius: 22rpx;
  background: rgba(255,253,248,.78);
  color: #2b261f;
  font-size: 48rpx;
}

.calendar-head text:first-child {
  display: block;
  color: #817364;
  font-size: 23rpx;
  font-weight: 800;
}

.calendar-head text:last-child {
  display: block;
  margin-top: 4rpx;
  font-family: "Songti SC", "STSong", serif;
  font-size: 34rpx;
  font-weight: 900;
}

.weekday-row,
.calendar-grid {
  display: flex;
  flex-wrap: wrap;
  width: 100%;
}

.weekday-row {
  margin-bottom: 10rpx;
  color: #817364;
  text-align: center;
  font-size: 22rpx;
  font-weight: 800;
}

.weekday-row text {
  width: 14.285714%;
}

.calendar-date {
  width: 14.285714%;
  height: 84rpx;
  margin: 0;
  padding: 4rpx;
  box-sizing: border-box;
  border-radius: 0;
  background: transparent;
  color: #2b261f;
  font-size: 24rpx;
}

.calendar-cell {
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: 18rpx;
  background: rgba(255,253,248,.62);
}

.calendar-cell text {
  display: block;
  line-height: 1.2;
}

.calendar-date.done .calendar-cell text:last-child {
  color: #2e7059;
}

.calendar-date.partial .calendar-cell text:last-child {
  color: #d49a41;
}

.calendar-date.missed .calendar-cell text:last-child {
  color: #e78b66;
}

.calendar-date.is-selected .calendar-cell {
  background: linear-gradient(180deg, #2f8a66, #17563d);
  color: #fff;
}

.calendar-date.is-muted .calendar-cell {
  opacity: .42;
}

.selected-date {
  display: flex;
  justify-content: space-between;
  margin-top: 22rpx;
  border: 2rpx solid rgba(226,207,175,.78);
  border-radius: 24rpx;
  background: rgba(255,253,248,.72);
  padding: 22rpx;
  color: #817364;
  font-size: 24rpx;
  font-weight: 800;
}
