.progress-hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 34rpx;
  margin-bottom: 26rpx;
}

.progress-hero > view:first-child {
  flex: 1;
  min-width: 0;
  padding-right: 26rpx;
}

.progress-kicker {
  color: #607582;
  font-size: 24rpx;
  font-weight: 800;
}

.progress-title {
  display: block;
  margin: 10rpx 0 12rpx;
  font-family: "Songti SC", "STSong", serif;
  font-size: 44rpx;
  font-weight: 900;
  line-height: 1.12;
}

.progress-ring {
  flex: 0 0 172rpx;
  width: 172rpx;
  height: 138rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 2rpx solid rgba(18,125,143,.18);
  border-radius: 28rpx;
  background: linear-gradient(180deg, rgba(248,252,255,.92), rgba(228,247,252,.82));
  box-shadow: inset 0 2rpx 0 rgba(255,255,255,.88);
}

.progress-ring text:first-child {
  color: #127d8f;
  font-size: 44rpx;
  font-weight: 950;
  line-height: 1;
}

.progress-ring text:last-child {
  margin-top: 8rpx;
  color: #607582;
  font-size: 20rpx;
  font-weight: 800;
}

.flag-card,
.mood-card,
.calendar-card {
  position: relative;
  margin-bottom: 26rpx;
  padding: 32rpx;
}

.flag-card::before {
  content: "";
  position: absolute;
  top: -2rpx;
  right: 52rpx;
  width: 94rpx;
  height: 32rpx;
  border-radius: 0 0 14rpx 14rpx;
  background: rgba(87,183,211,.4);
}

.flag-title {
  display: block;
  margin: 26rpx 0 12rpx;
  font-family: "Songti SC", "STSong", serif;
  font-size: 42rpx;
  font-weight: 900;
  line-height: 1.18;
}

.meter-card {
  margin-top: 26rpx;
  border: 2rpx solid rgba(169,194,205,.7);
  border-radius: 26rpx;
  background: linear-gradient(135deg, rgba(222,244,249,.74), rgba(248,252,255,.84));
  padding: 26rpx;
}

.meter-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  color: #607582;
  font-size: 24rpx;
  font-weight: 850;
}

.meter-head text:last-child {
  color: #127d8f;
  font-size: 58rpx;
  line-height: 1;
  font-weight: 950;
}

.reason-panel {
  margin-top: 24rpx;
  border-top: 2rpx dashed rgba(169,194,205,.72);
  padding-top: 22rpx;
}

.reason-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  margin-top: 18rpx;
}

.reason-tile {
  width: 48%;
  min-height: 132rpx;
  display: flex;
  align-items: flex-start;
  border: 2rpx solid rgba(18,125,143,.15);
  border-radius: 24rpx;
  background: linear-gradient(180deg, rgba(248,252,255,.94), rgba(229,246,250,.78));
  box-shadow: inset 0 2rpx 0 rgba(255,255,255,.86);
  padding: 18rpx;
  margin-bottom: 14rpx;
}

.reason-tag {
  flex: 0 0 58rpx;
  min-height: 42rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 14rpx;
  border-radius: 999rpx;
  background: #127d8f;
  color: #fff;
  font-size: 20rpx;
  font-weight: 950;
}

.reason-label {
  display: block;
  color: #17323b;
  font-size: 28rpx;
  font-weight: 950;
  line-height: 1.2;
}

.reason-helper {
  display: block;
  margin-top: 8rpx;
  color: #607582;
  font-size: 22rpx;
  line-height: 1.35;
  font-weight: 750;
}

.mood-button {
  flex: 1;
  min-height: 78rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 10rpx;
  border: 2rpx solid rgba(169,194,205,.72);
  border-radius: 999rpx;
  background: rgba(248,252,255,.78);
  color: #162a34;
  font-size: 24rpx;
  font-weight: 850;
}

.mood-grid {
  display: flex;
  flex-wrap: nowrap;
  margin-top: 18rpx;
}

.mood-button:last-child {
  margin-right: 0;
}

.mood-button.is-active {
  border-color: rgba(18,125,143,.44);
  background: #dff3f7;
  color: #127d8f;
}

.log-card {
  margin-top: 26rpx;
  border-top: 2rpx dashed rgba(169,194,205,.72);
  padding-top: 22rpx;
}

.log-row {
  display: flex;
  align-items: center;
  padding: 14rpx 0;
  border-bottom: 1rpx solid rgba(169,194,205,.58);
  color: #607582;
  font-size: 23rpx;
  font-weight: 800;
}

.log-row text:first-child {
  width: 96rpx;
  flex: 0 0 96rpx;
}

.log-row text:nth-child(2) {
  flex: 1;
  min-width: 0;
  padding: 0 12rpx;
}

.log-row text:last-child {
  width: 80rpx;
  flex: 0 0 80rpx;
  color: #127d8f;
  text-align: right;
}

.empty-flag-image {
  display: block;
  width: 184rpx;
  height: 184rpx;
  margin: 0 auto 26rpx;
  border-radius: 36rpx;
  box-shadow: 0 16rpx 34rpx rgba(21,65,86,.12);
}

.empty-title {
  display: block;
  margin-bottom: 12rpx;
  font-family: "Songti SC", "STSong", serif;
  font-size: 42rpx;
  font-weight: 900;
}

.empty-state .primary-button {
  margin-top: 28rpx;
}

.calendar-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  text-align: center;
  margin-bottom: 18rpx;
}

.calendar-card {
  margin-bottom: 26rpx;
  padding: 24rpx;
  background:
    linear-gradient(180deg, rgba(248,252,255,.9), rgba(232,243,248,.82)),
    radial-gradient(circle at 86% 10%, rgba(187,225,236,.55), transparent 28%);
}

.calendar-head > view {
  flex: 1;
  min-width: 0;
}

.calendar-head button {
  width: 76rpx;
  height: 76rpx;
  border-radius: 22rpx;
  background: rgba(248,252,255,.72);
  color: #162a34;
  font-size: 48rpx;
}

.calendar-head text:first-child {
  display: block;
  color: #607582;
  font-size: 23rpx;
  font-weight: 800;
}

.calendar-head text:last-child {
  display: block;
  margin-top: 4rpx;
  font-family: "Songti SC", "STSong", serif;
  font-size: 34rpx;
  font-weight: 900;
}

.weekday-row,
.calendar-grid {
  display: flex;
  flex-wrap: wrap;
  width: 100%;
}

.weekday-row {
  margin-bottom: 10rpx;
  color: #607582;
  text-align: center;
  font-size: 22rpx;
  font-weight: 800;
}

.weekday-row text {
  width: 14.285714%;
}

.calendar-date {
  width: 14.285714%;
  height: 84rpx;
  margin: 0;
  padding: 4rpx;
  box-sizing: border-box;
  border-radius: 0;
  background: transparent;
  color: #162a34;
  font-size: 24rpx;
}

.calendar-cell {
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: 18rpx;
  background: rgba(248,252,255,.58);
}

.calendar-cell text {
  display: block;
  line-height: 1.2;
}

.calendar-date.done .calendar-cell text:last-child {
  color: #127d8f;
}

.calendar-date.partial .calendar-cell text:last-child {
  color: #2c8fb6;
}

.calendar-date.missed .calendar-cell text:last-child {
  color: #6c7f8c;
}

.calendar-date.is-selected .calendar-cell {
  background: linear-gradient(180deg, #19a2b5, #086578);
  color: #fff;
}

.calendar-date.is-muted .calendar-cell {
  opacity: .42;
}

.selected-date {
  display: flex;
  justify-content: space-between;
  margin-top: 22rpx;
  border: 2rpx solid rgba(169,194,205,.62);
  border-radius: 24rpx;
  background: rgba(248,252,255,.68);
  padding: 22rpx;
  color: #607582;
  font-size: 24rpx;
  font-weight: 800;
}
