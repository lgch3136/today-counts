.share-card {
  position: relative;
  min-height: 760rpx;
  overflow: hidden;
  border: 2rpx solid rgba(226,207,175,.9);
  border-radius: 30rpx;
  box-shadow: 0 24rpx 60rpx rgba(78,51,27,.15);
}

.share-bg,
.share-mask {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.share-mask {
  background: linear-gradient(180deg, rgba(255,249,238,.08), rgba(255,249,238,.7));
}

.stamp-mark {
  position: absolute;
  right: 38rpx;
  top: 48rpx;
  width: 154rpx;
  height: 154rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid rgba(183,91,66,.72);
  border-radius: 50%;
  color: #9d503f;
  font-size: 30rpx;
  font-weight: 950;
  transform: rotate(-9deg);
}

.share-head {
  position: absolute;
  left: 42rpx;
  right: 220rpx;
  top: 48rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.share-head text {
  min-height: 42rpx;
  border-radius: 999rpx;
  background: rgba(220,236,225,.92);
  color: #2e7059;
  padding: 0 16rpx;
  font-size: 23rpx;
  font-weight: 900;
  line-height: 42rpx;
}

.share-main {
  position: absolute;
  left: 42rpx;
  right: 42rpx;
  top: 320rpx;
}

.share-title {
  display: block;
  max-width: 570rpx;
  font-family: "Songti SC", "STSong", serif;
  font-size: 52rpx;
  font-weight: 900;
  line-height: 1.15;
}

.share-quote {
  display: block;
  max-width: 620rpx;
  margin-top: 26rpx;
  color: #817364;
  font-size: 27rpx;
  line-height: 1.6;
}

.share-stats {
  position: absolute;
  left: 42rpx;
  right: 42rpx;
  bottom: 42rpx;
  display: flex;
  margin: 0 -7rpx;
}

.share-stats view {
  flex: 1;
  min-width: 0;
  min-height: 126rpx;
  margin: 0 7rpx;
  border: 2rpx solid rgba(226,207,175,.82);
  border-radius: 24rpx;
  background: rgba(255,253,248,.82);
  padding: 18rpx;
}

.share-stats text:first-child {
  display: block;
  color: #817364;
  font-size: 22rpx;
  font-weight: 800;
}

.share-stats text:last-child {
  display: block;
  margin-top: 12rpx;
  color: #2e7059;
  font-size: 36rpx;
  font-weight: 950;
}

.share-actions {
  display: flex;
  flex-wrap: wrap;
  margin: 26rpx -8rpx;
}

.share-actions button {
  flex: 1 1 280rpx;
  margin: 0 8rpx 16rpx;
}

.share-actions .primary-button {
  flex-basis: 100%;
  width: auto;
}

.reflection-card {
  padding: 30rpx;
  margin: 26rpx 0;
}

.reflection-card text:last-child {
  display: block;
  margin-top: 18rpx;
  color: #817364;
  font-size: 27rpx;
  line-height: 1.7;
}

.poster-canvas {
  position: fixed;
  left: -9999px;
  top: -9999px;
  width: 1080px;
  height: 1080px;
}
