.share-card {
  position: relative;
  min-height: 820rpx;
  overflow: hidden;
  border: 0;
  border-radius: 20rpx;
  box-shadow: 0 28rpx 70rpx rgba(78,51,27,.18);
}

.share-bg,
.share-mask {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.share-mask {
  background: linear-gradient(180deg, rgba(255,249,238,.02), rgba(255,249,238,.3) 58%, rgba(255,249,238,.76));
}

.poster-mark {
  position: absolute;
  right: 38rpx;
  top: 42rpx;
  width: 136rpx;
  min-height: 74rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 2rpx solid rgba(46,112,89,.18);
  border-radius: 18rpx;
  background: rgba(255,253,248,.62);
  color: #2e7059;
  font-size: 22rpx;
  font-weight: 950;
  line-height: 1.05;
  text-transform: uppercase;
}

.poster-mark text:last-child {
  margin-top: 6rpx;
  color: #817364;
  font-size: 20rpx;
}

.share-head {
  position: absolute;
  left: 40rpx;
  right: 190rpx;
  top: 42rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.share-head text {
  min-height: 42rpx;
  border-radius: 999rpx;
  background: rgba(255,253,248,.72);
  color: #2e7059;
  padding: 0 16rpx;
  font-size: 23rpx;
  font-weight: 900;
  line-height: 42rpx;
}

.share-main {
  position: absolute;
  left: 50rpx;
  right: 50rpx;
  top: 224rpx;
}

.share-title {
  display: block;
  max-width: 610rpx;
  font-family: "Songti SC", "STSong", serif;
  font-size: 60rpx;
  font-weight: 900;
  line-height: 1.15;
}

.share-quote {
  display: block;
  max-width: 600rpx;
  margin-top: 30rpx;
  color: #817364;
  font-size: 29rpx;
  line-height: 1.7;
}

.share-stats {
  position: absolute;
  left: 50rpx;
  right: 50rpx;
  bottom: 48rpx;
  display: flex;
  border-top: 2rpx solid rgba(46,112,89,.16);
  padding-top: 22rpx;
}

.share-stats view {
  flex: 1;
  min-width: 0;
  min-height: 92rpx;
  padding-right: 18rpx;
}

.share-stats text:first-child {
  display: block;
  color: #817364;
  font-size: 22rpx;
  font-weight: 800;
}

.share-stats text:last-child {
  display: block;
  margin-top: 12rpx;
  color: #2e7059;
  font-size: 36rpx;
  font-weight: 950;
}

.share-actions {
  display: flex;
  flex-wrap: wrap;
  margin: 26rpx -8rpx;
}

.share-actions button {
  flex: 1 1 280rpx;
  margin: 0 8rpx 16rpx;
}

.share-actions .primary-button {
  flex-basis: 100%;
  width: auto;
}

.reflection-card {
  padding: 30rpx;
  margin: 26rpx 0;
}

.reflection-card text:last-child {
  display: block;
  margin-top: 18rpx;
  color: #817364;
  font-size: 27rpx;
  line-height: 1.7;
}

.poster-canvas {
  position: fixed;
  left: -9999px;
  top: -9999px;
  width: 1080px;
  height: 1080px;
}
