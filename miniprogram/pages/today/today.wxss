.hero-card {
  position: relative;
  min-height: 310rpx;
  overflow: hidden;
  border-radius: 28rpx;
  box-shadow: 0 30rpx 70rpx rgba(21, 65, 86, 0.16);
}

.hero-bg,
.hero-mask {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.hero-mask {
  background: linear-gradient(180deg, rgba(245,251,253,.02) 0%, rgba(232,245,250,.28) 58%, rgba(244,250,252,.9) 100%);
}

.date-pill {
  position: absolute;
  left: 42rpx;
  top: 34rpx;
  min-height: 48rpx;
  display: flex;
  align-items: center;
  border-radius: 999rpx;
  background: rgba(248,252,255,.78);
  color: #607582;
  padding: 0 18rpx;
  font-size: 25rpx;
  font-weight: 800;
}

.date-pill::before {
  content: "";
  width: 12rpx;
  height: 12rpx;
  margin-right: 12rpx;
  border-radius: 999rpx;
  background: #127d8f;
}

.streak-pill {
  position: absolute;
  right: 42rpx;
  top: 34rpx;
  display: flex;
  align-items: center;
  gap: 6rpx;
  min-height: 76rpx;
  border: 2rpx solid rgba(18, 125, 143, 0.2);
  border-radius: 999rpx;
  background: rgba(248,252,255,.78);
  color: #127d8f;
  padding: 0 22rpx;
  box-shadow: 0 12rpx 28rpx rgba(21,65,86,.1);
  font-size: 23rpx;
  font-weight: 900;
}

.streak-number {
  font-size: 36rpx;
  line-height: 1;
}

.hero-copy {
  position: absolute;
  left: 42rpx;
  right: 42rpx;
  bottom: 32rpx;
}

.hero-title {
  display: block;
  font-family: "Songti SC", "STSong", serif;
  font-size: 44rpx;
  font-weight: 900;
  line-height: 1.08;
  white-space: pre-line;
}

.hero-subtitle {
  display: block;
  margin-top: 12rpx;
  color: #526a78;
  font-size: 24rpx;
  line-height: 1.45;
}

.reminder-strip {
  display: flex;
  align-items: center;
  min-height: 106rpx;
  margin-top: 22rpx;
  border: 2rpx solid rgba(18,125,143,.18);
  border-radius: 28rpx;
  background: linear-gradient(135deg, rgba(228,247,252,.96), rgba(248,252,255,.9));
  box-shadow: 0 14rpx 34rpx rgba(18,125,143,.1), inset 0 2rpx 0 rgba(255,255,255,.9);
  padding: 18rpx 20rpx;
}

.reminder-symbol {
  position: relative;
  width: 54rpx;
  height: 54rpx;
  flex: 0 0 54rpx;
  margin-right: 18rpx;
  border: 3rpx solid #127d8f;
  border-radius: 50%;
}

.reminder-symbol::before,
.reminder-symbol::after {
  content: "";
  position: absolute;
  left: 25rpx;
  top: 12rpx;
  width: 3rpx;
  height: 18rpx;
  border-radius: 999rpx;
  background: #127d8f;
}

.reminder-symbol::after {
  top: 27rpx;
  width: 16rpx;
  height: 3rpx;
}

.reminder-main {
  flex: 1;
  min-width: 0;
}

.reminder-main text:first-child {
  display: block;
  color: #18313a;
  font-size: 28rpx;
  font-weight: 950;
}

.reminder-main text:last-child {
  display: block;
  margin-top: 8rpx;
  color: #607582;
  font-size: 23rpx;
  font-weight: 750;
}

.reminder-action {
  min-width: 92rpx;
  min-height: 54rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: #127d8f;
  color: #fff;
  font-size: 24rpx;
  font-weight: 900;
}

.compose-card,
.status-card {
  position: relative;
  margin-top: 24rpx;
  padding: 32rpx;
}

.compose-card::before,
.status-card::before {
  content: "";
  position: absolute;
  top: -2rpx;
  right: 52rpx;
  width: 94rpx;
  height: 32rpx;
  border-radius: 0 0 14rpx 14rpx;
  background: rgba(87, 183, 211, 0.42);
}

.field-label {
  display: flex;
  justify-content: space-between;
  margin: 26rpx 0 14rpx;
  color: #243d48;
  font-size: 26rpx;
  font-weight: 850;
}

.goal-input {
  width: 100%;
  min-height: 154rpx;
  border: 2rpx solid rgba(169,194,205,.76);
  border-radius: 26rpx;
  background: rgba(248,252,255,.96);
  color: #162a34;
  padding: 24rpx;
  font-size: 32rpx;
  line-height: 1.45;
}

.quick-grid {
  display: flex;
  flex-wrap: wrap;
  margin: 20rpx -7rpx 0;
}

.quick-card {
  flex: 1 1 190rpx;
  min-height: 126rpx;
  margin: 0 7rpx 14rpx;
  border: 2rpx solid rgba(169,194,205,.7);
  border-radius: 24rpx;
  background: rgba(248,252,255,.72);
  padding: 18rpx;
}

.quick-card text {
  display: block;
  color: #127d8f;
  font-size: 23rpx;
  font-weight: 900;
}

.quick-card input,
.time-value {
  margin-top: 16rpx;
  color: #607582;
  font-size: 24rpx;
}

.wide-button {
  width: 100%;
  margin-top: 24rpx;
}

.summary-grid {
  display: flex;
  margin: 24rpx -8rpx;
}

.summary-grid > view {
  flex: 1;
  min-height: 140rpx;
  margin: 0 8rpx;
  border: 2rpx solid rgba(169,194,205,.7);
  border-radius: 24rpx;
  background: rgba(248,252,255,.76);
  padding: 22rpx;
}

.summary-grid text:first-child,
.flag-index {
  display: block;
  color: #607582;
  font-size: 23rpx;
  font-weight: 800;
}

.summary-number {
  display: block;
  margin-top: 10rpx;
  color: #127d8f;
  font-size: 46rpx;
  font-weight: 950;
}

.flag-list {
  display: flex;
  flex-direction: column;
}

.flag-summary {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 14rpx;
  border: 2rpx solid rgba(169,194,205,.7);
  border-radius: 24rpx;
  background: rgba(248,252,255,.76);
  padding: 22rpx;
}

.flag-goal {
  display: block;
  margin-top: 6rpx;
  font-size: 30rpx;
  font-weight: 850;
}

.flag-progress {
  color: #127d8f;
  font-size: 40rpx;
  font-weight: 950;
}
