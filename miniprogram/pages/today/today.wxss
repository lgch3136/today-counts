.hero-card {
  position: relative;
  min-height: 620rpx;
  overflow: hidden;
  border-radius: 28rpx;
  box-shadow: 0 30rpx 70rpx rgba(78, 51, 27, 0.17);
}

.hero-bg,
.hero-mask {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.hero-mask {
  background: linear-gradient(180deg, rgba(255, 251, 243, 0.1) 0%, rgba(255, 249, 238, 0.72) 55%, rgba(255, 249, 238, 0.98) 100%);
}

.date-pill {
  position: absolute;
  left: 42rpx;
  top: 266rpx;
  min-height: 48rpx;
  display: flex;
  align-items: center;
  border-radius: 999rpx;
  background: rgba(255, 251, 243, 0.74);
  color: #817364;
  padding: 0 18rpx;
  font-size: 25rpx;
  font-weight: 800;
}

.date-pill::before {
  content: "";
  width: 12rpx;
  height: 12rpx;
  margin-right: 12rpx;
  border-radius: 999rpx;
  background: #2e7059;
}

.streak-pill {
  position: absolute;
  right: 42rpx;
  top: 326rpx;
  display: flex;
  align-items: center;
  gap: 6rpx;
  min-height: 76rpx;
  border: 2rpx solid rgba(46, 112, 89, 0.2);
  border-radius: 999rpx;
  background: rgba(255, 249, 238, 0.78);
  color: #2e7059;
  padding: 0 22rpx;
  box-shadow: 0 12rpx 28rpx rgba(85, 52, 28, 0.1);
  font-size: 23rpx;
  font-weight: 900;
}

.streak-number {
  font-size: 36rpx;
  line-height: 1;
}

.hero-copy {
  position: absolute;
  left: 42rpx;
  right: 42rpx;
  bottom: 46rpx;
}

.hero-title {
  display: block;
  font-family: "Songti SC", "STSong", serif;
  font-size: 62rpx;
  font-weight: 900;
  line-height: 1.08;
  white-space: pre-line;
}

.hero-subtitle {
  display: block;
  margin-top: 18rpx;
  color: #6f6255;
  font-size: 26rpx;
  line-height: 1.65;
}

.compose-card,
.status-card {
  position: relative;
  margin-top: 34rpx;
  padding: 32rpx;
}

.compose-card::before,
.status-card::before {
  content: "";
  position: absolute;
  top: -2rpx;
  right: 52rpx;
  width: 94rpx;
  height: 32rpx;
  border-radius: 0 0 14rpx 14rpx;
  background: rgba(245, 203, 124, 0.76);
}

.field-label {
  display: flex;
  justify-content: space-between;
  margin: 26rpx 0 14rpx;
  color: #405045;
  font-size: 26rpx;
  font-weight: 850;
}

.goal-input {
  width: 100%;
  min-height: 154rpx;
  border: 2rpx solid rgba(226,207,175,.95);
  border-radius: 26rpx;
  background: rgba(255,253,248,.96);
  color: #2b261f;
  padding: 24rpx;
  font-size: 32rpx;
  line-height: 1.45;
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
  margin: 24rpx 0;
}

.quick-card {
  min-height: 126rpx;
  border: 2rpx solid rgba(226,207,175,.84);
  border-radius: 24rpx;
  background: rgba(255,253,248,.72);
  padding: 18rpx;
}

.quick-card text {
  display: block;
  color: #2e7059;
  font-size: 23rpx;
  font-weight: 900;
}

.quick-card input,
.time-value {
  margin-top: 16rpx;
  color: #817364;
  font-size: 24rpx;
}

.wide-button {
  width: 100%;
}

.summary-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  margin: 24rpx 0;
}

.summary-grid > view {
  min-height: 140rpx;
  border: 2rpx solid rgba(226,207,175,.84);
  border-radius: 24rpx;
  background: rgba(255,253,248,.76);
  padding: 22rpx;
}

.summary-grid text:first-child,
.flag-index {
  display: block;
  color: #817364;
  font-size: 23rpx;
  font-weight: 800;
}

.summary-number {
  display: block;
  margin-top: 10rpx;
  color: #2e7059;
  font-size: 46rpx;
  font-weight: 950;
}

.flag-list {
  display: grid;
  gap: 14rpx;
}

.flag-summary {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
  border: 2rpx solid rgba(226,207,175,.84);
  border-radius: 24rpx;
  background: rgba(255,253,248,.76);
  padding: 22rpx;
}

.flag-goal {
  display: block;
  margin-top: 6rpx;
  font-size: 30rpx;
  font-weight: 850;
}

.flag-progress {
  color: #2e7059;
  font-size: 40rpx;
  font-weight: 950;
}
